[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.12"
dependencies = [
    "dj-database-url>=2.3.0",
    "django>=6.0",
    "django-allauth>=65.4.0",
    "django-ninja>=1.4.0",
    "granian>=2.0.0",
    "psycopg2-binary>=2.9.10",
    "python-decouple>=3.8",
    "django-cors-headers>=4.7.0",
    "django-anymail[amazon-ses]>=13.0",
    "structlog>=24.4.0",
    "django-browser-reload>=1.18.0",
    "sentry-sdk>=2.22.0",
    "whitenoise>=6.9.0",
    "django-widget-tweaks>=1.5.0",
    "django-debug-toolbar>=5.1.0",
    "django-valkey>=0.4.0",
    "django-vite>=3.1.0",
    "dbos>=2.1.0",
]

[dependency-groups]
dev = [
    "setproctitle>=1.3.6",
    "textual>=3.1.0",
]
